<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EfGui.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="560"
        x:Class="EfGui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="900" Height="560"
        MinWidth="700" MinHeight="400"
        Title="{Binding WindowTitle}">

    <Design.DataContext>
      <!-- This only sets the DataContext for the previewer in an IDE,
               to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
      <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
      <!-- Fixed .NET-purple accent: system accent colors can be near-gray, which
           would defeat the purpose of emphasizing the primary action. -->
      <SolidColorBrush x:Key="AccentBrush" Color="#512BD4"/>
      <SolidColorBrush x:Key="AccentBrushPointerOver" Color="#6A48DB"/>
      <SolidColorBrush x:Key="AccentBrushPressed" Color="#3F22A3"/>
    </Window.Resources>

    <Window.Styles>
      <!-- Stock FluentTheme ships no Button.accent class styling; define it explicitly.
           Styled on the template presenter directly, which outranks the TemplateBinding. -->
      <Style Selector="Button.accent /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
      </Style>
      <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{StaticResource AccentBrushPointerOver}"/>
        <Setter Property="Foreground" Value="White"/>
      </Style>
      <Style Selector="Button.accent:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{StaticResource AccentBrushPressed}"/>
        <Setter Property="Foreground" Value="White"/>
      </Style>
      <!-- The presenter styles above outrank the theme's :disabled state, so dim explicitly. -->
      <Style Selector="Button.accent:disabled">
        <Setter Property="Opacity" Value="0.45"/>
      </Style>

      <Style Selector="StackPanel.sidebar > Button">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0 2"/>
      </Style>
      <!-- Captions wrap instead of clipping when the sidebar is dragged narrow. -->
      <Style Selector="StackPanel.sidebar > Button TextBlock">
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="TextAlignment" Value="Center"/>
      </Style>
      <Style Selector="TextBlock.section">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="LetterSpacing" Value="0.4"/>
        <Setter Property="Opacity" Value="0.8"/>
      </Style>
      <Style Selector="StackPanel.sidebar > TextBlock.section">
        <Setter Property="Margin" Value="0 16 0 4"/>
      </Style>
      <Style Selector="Button.destructive">
        <Setter Property="Foreground" Value="#D2685E"/>
      </Style>
      <Style Selector="GridSplitter#SidebarSplitter:pointerover">
        <Setter Property="Background" Value="#40808080"/>
      </Style>
      <!-- Always occupies its row; fades in instead of shifting the layout. -->
      <Style Selector="ProgressBar#BusyBar">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="Transitions">
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
          </Transitions>
        </Setter>
      </Style>
      <Style Selector="ProgressBar#BusyBar.active">
        <Setter Property="Opacity" Value="1"/>
      </Style>
    </Window.Styles>

    <Grid x:Name="RootGrid" RowDefinitions="Auto, *, Auto">
      <Grid.ColumnDefinitions>
        <!-- Min fits the longest action caption; the console column min (not a fixed max
             here) is what bounds how far the sidebar can grow. -->
        <ColumnDefinition Width="240" MinWidth="200"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*" MinWidth="320"/>
      </Grid.ColumnDefinitions>

      <!-- Top bar: profile cluster only. -->
      <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                  Margin="16 16 16 28" Orientation="Horizontal" Spacing="8"
                  HorizontalAlignment="Center">
        <TextBlock Text="Profile:" VerticalAlignment="Center"/>
        <ComboBox MinWidth="260" VerticalAlignment="Center"
                  ItemsSource="{Binding Profiles}"
                  SelectedItem="{Binding SelectedProfile}"
                  DisplayMemberBinding="{Binding Name}"
                  PlaceholderText="Add a profile to get started"/>
        <Button VerticalAlignment="Stretch" Command="{Binding EditProfile}"
                ToolTip.Tip="Edit the selected profile"
                AutomationProperties.Name="Edit profile">
          <PathIcon Width="14" Height="14"
                    Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a.996.996 0 0 0 0-1.41l-2.34-2.34a.996.996 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
        </Button>
        <Button VerticalAlignment="Stretch" Command="{Binding AddProfile}"
                ToolTip.Tip="Add a new profile"
                AutomationProperties.Name="Add profile">
          <PathIcon Width="14" Height="14"
                    Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
        </Button>
      </StackPanel>

      <StackPanel Classes="sidebar" Grid.Row="1" Grid.Column="0" Margin="16 0 0 0">
        <TextBlock Classes="section" Text="Create migration" Margin="0 0 0 4"/>
        <Grid ColumnDefinitions="*, Auto" Margin="0 2">
          <TextBox Grid.Column="0" Text="{Binding MigrationName}"
                   PlaceholderText="MigrationName">
            <TextBox.KeyBindings>
              <KeyBinding Gesture="Enter" Command="{Binding CreateMigration}"/>
            </TextBox.KeyBindings>
          </TextBox>
          <Button Grid.Column="1" Classes="accent" Margin="6 0 0 0"
                  VerticalAlignment="Stretch"
                  Command="{Binding CreateMigration}"
                  ToolTip.Tip="Create migration — dotnet ef migrations add &lt;name&gt;"
                  AutomationProperties.Name="Create migration">
            <PathIcon Width="14" Height="14"
                      Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
          </Button>
        </Grid>

        <TextBlock Classes="section" Text="General actions"/>
        <Button Content="List migrations" Command="{Binding ListMigrations}"
                ToolTip.Tip="dotnet ef migrations list"/>
        <Button Content="Generate full migration script" Command="{Binding GenerateFullScript}"
                ToolTip.Tip="dotnet ef migrations script"/>
        <Button Content="Generate unapplied migration script" Command="{Binding GenerateUnappliedScript}"
                ToolTip.Tip="dotnet ef migrations script &lt;last-applied&gt; — determined from the database"/>
        <Button Content="Generate optimized model" Command="{Binding GenerateOptimizedModel}"
                ToolTip.Tip="dotnet ef dbcontext optimize"/>

        <TextBlock Classes="section" Text="Last migration actions"/>
        <Button Classes="destructive" Content="Remove from code" Command="{Binding RemoveLastFromCode}"
                ToolTip.Tip="dotnet ef migrations remove --force"/>
        <Button Content="Recreate and generate script" Command="{Binding RecreateAndGenerateScript}"
                ToolTip.Tip="migrations remove --force, then add with the same name, then script"/>
        <Button Content="Generate apply script" Command="{Binding GenerateApplyScript}"
                ToolTip.Tip="dotnet ef migrations script &lt;previous&gt; &lt;last&gt;"/>
        <Button Content="Generate rollback script" Command="{Binding GenerateRollbackScript}"
                ToolTip.Tip="dotnet ef migrations script &lt;last&gt; &lt;previous&gt;"/>
      </StackPanel>

      <GridSplitter x:Name="SidebarSplitter" Grid.Row="1" Grid.Column="1" Width="8"
                    Background="Transparent" ResizeDirection="Columns"
                    DoubleTapped="SidebarSplitter_DoubleTapped"/>

      <Grid Grid.Row="1" Grid.Column="2" Margin="0 0 16 0" RowDefinitions="Auto, *">
        <DockPanel Grid.Row="0" Margin="0 0 0 6">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6">
            <Button Content="Stop"
                    Background="#A93434" Foreground="White"
                    IsVisible="{Binding IsBusy}"
                    Command="{Binding CancelOperation}"
                    ToolTip.Tip="Cancel the running operation"/>
            <Button VerticalAlignment="Stretch" Command="{Binding ClearConsole}"
                    ToolTip.Tip="Clear console output"
                    AutomationProperties.Name="Clear console">
              <PathIcon Width="14" Height="14"
                        Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM4 12c0-4.42 3.58-8 8-8 1.85 0 3.55.63 4.9 1.69L5.69 16.9A7.902 7.902 0 0 1 4 12zm8 8c-1.85 0-3.55-.63-4.9-1.69L18.31 7.1A7.902 7.902 0 0 1 20 12c0 4.42-3.58 8-8 8z"/>
            </Button>
            <Button x:Name="ConsoleThemeButton" VerticalAlignment="Stretch" Padding="8 0"
                    ToolTip.Tip="Console background">
              <Border Width="16" Height="16" CornerRadius="3"
                      Background="{Binding ConsoleBackground}"
                      BorderBrush="#60808080" BorderThickness="1"/>
              <Button.Flyout>
                <Flyout Placement="BottomEdgeAlignedRight">
                  <ItemsControl ItemsSource="{Binding ConsoleThemes}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:ConsoleTheme">
                        <Button Background="Transparent" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left" Padding="8 6"
                                Click="ConsoleThemePreset_Click">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="16" Height="16" CornerRadius="3"
                                    Background="{Binding Swatch}"
                                    BorderBrush="#60808080" BorderThickness="1"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                          </StackPanel>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Flyout>
              </Button.Flyout>
            </Button>
          </StackPanel>
          <TextBlock Classes="section" Text="Output" VerticalAlignment="Center"/>
        </DockPanel>

        <Border Grid.Row="1" Background="{Binding ConsoleBackground}" CornerRadius="4">
          <Panel>
            <ScrollViewer x:Name="ScrollViewer" HorizontalScrollBarVisibility="Auto" Padding="12">
              <SelectableTextBlock x:Name="SelectableTextBlock"
                                   Foreground="#C7D5E8"
                                   FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                                   FontSize="{Binding ConsoleFontSize}"
                                   LineHeight="{Binding ConsoleLineHeight}"/>
            </ScrollViewer>
            <TextBlock x:Name="ConsoleHint"
                       Text="{Binding ConsoleHintText}"
                       Foreground="#6E7E92" TextAlignment="Center"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Panel>
        </Border>
      </Grid>

      <!-- Lives inside the 16px bottom gutter (4+4+8) so the gap below the console
           matches the right-hand gutter and nothing shifts when it fades in. -->
      <ProgressBar x:Name="BusyBar" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                   Height="4" Margin="16 4 16 8"
                   IsIndeterminate="{Binding IsBusy}"
                   Classes.active="{Binding IsBusy}"/>
    </Grid>
</Window>
