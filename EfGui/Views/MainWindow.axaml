<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EfGui.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="560"
        x:Class="EfGui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="900" Height="560"
        Title="EfGui">

    <Design.DataContext>
      <!-- This only sets the DataContext for the previewer in an IDE,
               to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
      <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
      <Style Selector="StackPanel.sidebar > Button">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="0 2"/>
      </Style>
      <Style Selector="StackPanel.sidebar > TextBlock.section">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Opacity" Value="0.7"/>
        <Setter Property="Margin" Value="0 10 0 2"/>
      </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, *, Auto">
      <StackPanel Grid.Row="0" Grid.Column="1" Margin="0 12 12 12" Orientation="Horizontal" Spacing="6">
        <TextBlock Text="Profile:" VerticalAlignment="Center"/>
        <ComboBox MinWidth="240" VerticalAlignment="Center"
                  ItemsSource="{Binding Profiles}"
                  SelectedItem="{Binding SelectedProfile}"
                  DisplayMemberBinding="{Binding Name}"/>
        <Button Content="Edit" VerticalAlignment="Stretch" Command="{Binding EditProfile}"/>
        <Button Content="Add" VerticalAlignment="Stretch" Command="{Binding AddProfile}"/>
        <Button Content="Clear console" VerticalAlignment="Stretch" Command="{Binding ClearConsole}"/>
        <ComboBox VerticalAlignment="Center" MinWidth="110"
                  ItemsSource="{Binding ConsoleThemes}"
                  SelectedItem="{Binding SelectedConsoleTheme}"
                  DisplayMemberBinding="{Binding Name}"/>
        <Button Content="Stop" VerticalAlignment="Stretch"
                Background="#A93434" Foreground="White"
                IsVisible="{Binding IsBusy}"
                Command="{Binding CancelOperation}"/>
      </StackPanel>

      <StackPanel Classes="sidebar" Width="200" Grid.Row="1" Grid.Column="0" Margin="12 0 12 12">
        <TextBlock Classes="section" Text="Create migration" Margin="0 0 0 2"/>
        <Grid ColumnDefinitions="*, Auto">
          <TextBox Grid.Column="0" Text="{Binding MigrationName}"
                   PlaceholderText="MigrationName" FontSize="12">
            <TextBox.KeyBindings>
              <KeyBinding Gesture="Enter" Command="{Binding CreateMigration}"/>
            </TextBox.KeyBindings>
          </TextBox>
          <Button Grid.Column="1" Content="+" Margin="4 0 0 0"
                  VerticalAlignment="Stretch"
                  Command="{Binding CreateMigration}"/>
        </Grid>

        <TextBlock Classes="section" Text="General actions"/>
        <Button Content="List migrations" Command="{Binding ListMigrations}"/>
        <Button Content="Generate full migration script" Command="{Binding GenerateFullScript}"/>
        <Button Content="Generate unapplied migration script" Command="{Binding GenerateUnappliedScript}"/>
        <Button Content="Generate optimized model" Command="{Binding GenerateOptimizedModel}"/>

        <TextBlock Classes="section" Text="Last migration actions"/>
        <Button Content="Remove from code" Command="{Binding RemoveLastFromCode}"/>
        <Button Content="Recreate and generate script" Command="{Binding RecreateAndGenerateScript}"/>
        <Button Content="Generate apply script" Command="{Binding GenerateApplyScript}"/>
        <Button Content="Generate rollback script" Command="{Binding GenerateRollbackScript}"/>
      </StackPanel>

      <Border Background="{Binding ConsoleBackground}" CornerRadius="4" Grid.Row="1" Grid.Column="1" VerticalAlignment="Stretch" Margin="0 0 12 12">
        <ScrollViewer x:Name="ScrollViewer" HorizontalScrollBarVisibility="Auto" Padding="8">
          <SelectableTextBlock x:Name="SelectableTextBlock"
                               Foreground="#C7D5E8"
                               FontFamily="Cascadia Mono,Consolas,Menlo,monospace"
                               FontSize="12"/>
        </ScrollViewer>
      </Border>

      <ProgressBar Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                   Height="4" Margin="12 0 12 8"
                   IsIndeterminate="{Binding IsBusy}"
                   IsVisible="{Binding IsBusy}"/>
    </Grid>
</Window>
